project_id  = "your-gcp-project-id"
region      = "us-central1"
github_repo = "BigCatTechnologies/bigcat-app"

# Redis (OAuthProxy cache storage)
redis_host    = "your-redis-host"
redis_port    = "6379"
redis_use_ssl = "false"

# Auth0 (non-secret)
auth0_domain         = "your-tenant.us.auth0.com"
auth0_jwks_uri       = "https://your-tenant.auth0.com/.well-known/jwks.json"
auth0_issuer         = "https://your-tenant.auth0.com/"
auth0_audience       = "https://your-api-audience"
auth0_auth_endpoint  = "https://your-tenant.auth0.com/authorize"
auth0_token_endpoint = "https://your-tenant.auth0.com/oauth/token"
auth0_spa_client_id  = "your-auth0-spa-client-id"      # Single Page Application (React frontend)
auth0_mcp_client_id  = "your-auth0-mcp-client-id"      # Regular Web Application (MCP OAuth proxy)
api_base_url         = "https://your-cloud-run-service-url"
auth0_redirect_path  = "/oauth/callback"

# ---------------------------------------------------------------------------
# Secrets — do NOT put these in terraform.tfvars.
# Set them as environment variables before running terraform apply:
#
#   export TF_VAR_db_password="..."
#   export TF_VAR_redis_password="..."
#   export TF_VAR_auth0_mcp_client_secret="..."
#
# Terraform automatically reads TF_VAR_* from the environment.
# ---------------------------------------------------------------------------
