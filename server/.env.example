REDIS_HOST=some-value
REDIS_PORT=some-value
REDIS_USE_SSL=some-value

AUTH0_JWKS_URI=some-value
AUTH0_ISSUER=some-value
AUTH0_AUDIENCE=some-value
AUTH0_AUTH_ENDPOINT=some-value
AUTH0_TOKEN_ENDPOINT=some-value
AUTH0_CLIENT_ID=some-value
AUTH0_CLIENT_SECRET=some-value
AUTH0_REDIRECT_PATH=some-value

# MCP OAuth proxy client — must have offline_access enabled in Auth0 API settings
# to allow refresh token issuance
AUTH0_MCP_CLIENT_ID=some-value
AUTH0_MCP_CLIENT_SECRET=some-value

API_BASE_URL=some-value

# X (Twitter) API credentials — required for the post-to-X sharing feature
X_API_KEY=some-value
X_API_KEY_SECRET=some-value
X_ACCESS_TOKEN=some-value
X_ACCESS_TOKEN_SECRET=some-value