# Copy this file to server/.env and fill in your Auth0 values.
# DB and Redis values below match the docker-compose defaults — no changes needed for local dev.

DB_HOST=postgres
DB_PORT=5433
DB_NAME=bigcat
DB_USER=postgres
DB_PASSWORD=devpassword

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USE_SSL=false

AUTH0_JWKS_URI=https://dev-0qjni0szsyexnetg.us.auth0.com/.well-known/jwks.json
AUTH0_ISSUER=https://dev-0qjni0szsyexnetg.us.auth0.com/
AUTH0_AUDIENCE=https://api.bigcattechnologies.com
AUTH0_AUTH_ENDPOINT=https://dev-0qjni0szsyexnetg.us.auth0.com/authorize
AUTH0_TOKEN_ENDPOINT=https://dev-0qjni0szsyexnetg.us.auth0.com/oauth/token
AUTH0_REDIRECT_PATH=/mcp/auth/callback

AUTH0_MCP_CLIENT_ID=your-mcp-client-id
AUTH0_MCP_CLIENT_SECRET=your-mcp-client-secret

API_BASE_URL=http://localhost:3000

# Override CORS to allow the local Vite dev server
ALLOWED_ORIGINS=http://localhost:5173
